#!/bin/bash
# pre-commit hook — Run build safety checks before every commit
#
# Install: git config core.hooksPath .githooks
#
# Checks:
#   1. No phantom files (registered in CMake but missing on disk)
#   2. No orphaned source files (on disk but not in CMake)
#   3. No duplicate OBJECT library names
#   4. CMake configure succeeds
#
# Skip with: git commit --no-verify (use sparingly)

set -e

# Navigate to project root
cd "$(git rev-parse --show-toplevel)"

echo "=== Pre-commit: Build Safety Check ==="

# Run the build safety checker
if [ -f scripts/check_build_safety.sh ]; then
    bash scripts/check_build_safety.sh
    EXIT=$?
    if [ $EXIT -ne 0 ]; then
        echo ""
        echo "Pre-commit hook FAILED. Fix errors above before committing."
        exit 1
    fi
else
    echo "WARNING: scripts/check_build_safety.sh not found, skipping"
fi

echo "Pre-commit checks passed."
