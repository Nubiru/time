---
# .clang-tidy — Time Project
# C11 project — only enable checks that apply to C code.
# See: https://clang.llvm.org/extra/clang-tidy/

# Bug-prone patterns applicable to C
Checks: >
  -*,
  bugprone-branch-clone,
  bugprone-integer-division,
  bugprone-macro-parentheses,
  bugprone-misplaced-widening-cast,
  bugprone-redundant-branch-condition,
  bugprone-sizeof-expression,
  bugprone-suspicious-include,
  bugprone-suspicious-semicolon,
  bugprone-swapped-arguments,
  bugprone-terminating-continue,
  bugprone-too-small-loop-variable,
  misc-redundant-expression,
  misc-unused-parameters,
  readability-else-after-return,
  readability-misleading-indentation,
  readability-redundant-control-flow,
  readability-simplify-boolean-expr,

# We compile with -Wall -Wextra -Werror, which covers many C checks.
# clang-tidy adds deeper semantic analysis beyond what the compiler catches.

WarningsAsErrors: ''

HeaderFilterRegex: 'src/.*\.h$'

CheckOptions:
  - key: misc-unused-parameters.StrictMode
    value: false
