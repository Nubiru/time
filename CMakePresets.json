{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "native-debug",
      "displayName": "Native Debug",
      "description": "Native build with debug info (default development)",
      "binaryDir": "build-native",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "native-release",
      "displayName": "Native Release",
      "description": "Optimized native build",
      "binaryDir": "build-native-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "coverage",
      "displayName": "Coverage",
      "description": "Native build with gcov instrumentation",
      "binaryDir": "build-coverage",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Coverage"
      }
    },
    {
      "name": "sanitize",
      "displayName": "Sanitize",
      "description": "Native build with AddressSanitizer + UndefinedBehaviorSanitizer",
      "binaryDir": "build-sanitize",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Sanitize"
      }
    },
    {
      "name": "benchmark",
      "displayName": "Benchmark",
      "description": "Optimized native build for performance measurement",
      "binaryDir": "build-benchmark",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Benchmark"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "native-debug",
      "configurePreset": "native-debug"
    },
    {
      "name": "native-release",
      "configurePreset": "native-release"
    },
    {
      "name": "coverage",
      "configurePreset": "coverage"
    },
    {
      "name": "sanitize",
      "configurePreset": "sanitize"
    },
    {
      "name": "benchmark",
      "configurePreset": "benchmark"
    }
  ],
  "testPresets": [
    {
      "name": "native-debug",
      "configurePreset": "native-debug",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "jobs": 12
      }
    },
    {
      "name": "coverage",
      "configurePreset": "coverage",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "jobs": 12
      }
    },
    {
      "name": "sanitize",
      "configurePreset": "sanitize",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "jobs": 12
      }
    },
    {
      "name": "contract",
      "configurePreset": "native-debug",
      "filter": {
        "include": {
          "label": "contract"
        }
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "integration",
      "configurePreset": "native-debug",
      "filter": {
        "include": {
          "label": "integration"
        }
      },
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
